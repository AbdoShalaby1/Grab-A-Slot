generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

enum Role {
  user
  admin
}

model User {
  id           Int           @id @default(autoincrement())
  email        String        @unique
  passwordHash String
  name         String
  role         Role          @default(user)
  createdAt    DateTime      @default(now()) @db.Timestamp(0)
  appointments Appointment[]
  createdSlots TimeSlot[]    @relation("CreatedBy")
  adminCode    AdminCode?    @relation("GeneratedBy")
}

model TimeSlot {
  id          Int          @id @default(autoincrement())
  startAt     DateTime      @db.DateTime(0)
  endAt       DateTime      @db.DateTime(0)
  isActive    Boolean      @default(true)
  createdById Int
  createdBy   User         @relation("CreatedBy", fields: [createdById], references: [id])
  appointment Appointment?
  @@index([startAt])
  @@index([createdById])
  @@index([isActive])
}

model Appointment {
  id          Int      @id @default(autoincrement())
  userId      Int
  timeSlotId  Int      @unique
  adminCodeId Int
  createdAt   DateTime @default(now()) @db.Timestamp(0)
  user        User     @relation(fields: [userId], references: [id])
  timeSlot    TimeSlot @relation(fields: [timeSlotId], references: [id])
  adminCode   AdminCode @relation(fields: [adminCodeId], references: [id])
  @@index([userId])
  @@index([createdAt])
  @@index([adminCodeId])
}

model AdminCode {
  id        Int      @id @default(autoincrement())
  code      String   @unique
  adminId   Int      @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now()) @db.Timestamp(0)
  admin     User     @relation("GeneratedBy", fields: [adminId], references: [id])
  appointments Appointment[]
  @@index([code])
}
