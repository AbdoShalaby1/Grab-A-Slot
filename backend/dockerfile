FROM node:20-slim

# Install OpenSSL and CA certificates (Prisma needs these for WASM/engines)
RUN apt-get update -y && apt-get install -y openssl ca-certificates

WORKDIR /app

COPY package*.json ./

# Install dependencies - we use --unsafe-perm if there are permission issues with postinstall
RUN npm install

# Copy prisma schema before generating
COPY prisma ./prisma/

# FORCE the generation of the client for the current OS
RUN npx prisma generate

COPY . .

# Set production environment
ENV NODE_ENV=production
ENV PORT=4000
EXPOSE 4000

# Clean start
CMD npx prisma migrate deploy && node index.js